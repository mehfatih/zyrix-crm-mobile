{
  "expo": {
    "name": "zyrix-crm-mobile",
    "slug": "zyrix-crm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.journaliste.zyrixcrmmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "20f8ba49-975c-4f3b-a5f5-1bf7f09c2d1c"
      }
    },
    "owner": "journaliste",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-localization"
    ]
  }
}
